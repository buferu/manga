    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Hidden canvas for processing -->
    <canvas id="processingCanvas" style="display:none;"></canvas>

    <footer class="footer">
        <p>AspectLens — Профессиональный анализатор изображений • Создано с ❤️</p>
    </footer>

    <script>
        // ============ STATE ============
        const state = {
            images: [],
            currentIndex: 0,
            currentImage: null,
            currentFile: null,
            rotation: 0,
            flipped: false,
            zoom: 1,
            selectedCropRatio: null,
            history: JSON.parse(localStorage.getItem('aspectlens_history') || '[]')
        };

        const RATIOS = [
            { name: '1:1', w: 1, h: 1 },
            { name: '1:4', w: 1, h: 4 },
            { name: '4:1', w: 4, h: 1 },
            { name: '1:8', w: 1, h: 8 },
            { name: '8:1', w: 8, h: 1 },
            { name: '2:3', w: 2, h: 3 },
            { name: '3:2', w: 3, h: 2 },
            { name: '3:4', w: 3, h: 4 },
            { name: '4:3', w: 4, h: 3 },
            { name: '4:5', w: 4, h: 5 },
            { name: '5:4', w: 5, h: 4 },
            { name: '9:16', w: 9, h: 16 },
            { name: '16:9', w: 16, h: 9 },
            { name: '21:9', w: 21, h: 9 }
        ];

        const PLATFORMS = {
            social: [
                { name: 'Instagram Пост', ratio: '1:1', dims: '1080×1080', icon: '📸' },
                { name: 'Instagram Story', ratio: '9:16', dims: '1080×1920', icon: '📱' },
                { name: 'Instagram Reels', ratio: '9:16', dims: '1080×1920', icon: '🎬' },
                { name: 'Facebook Пост', ratio: '16:9', dims: '1200×675', icon: '👤' },
                { name: 'Facebook Обложка', ratio: '21:9', dims: '820×312', icon: '🖼️' },
                { name: 'Twitter Пост', ratio: '16:9', dims: '1200×675', icon: '🐦' },
                { name: 'YouTube Превью', ratio: '16:9', dims: '1280×720', icon: '▶️' },
                { name: 'TikTok Видео', ratio: '9:16', dims: '1080×1920', icon: '🎵' },
                { name: 'Pinterest Пин', ratio: '2:3', dims: '1000×1500', icon: '📌' },
                { name: 'LinkedIn Баннер', ratio: '4:1', dims: '1584×396', icon: '💼' },
                { name: 'Telegram Стикер', ratio: '1:1', dims: '512×512', icon: '✈️' },
                { name: 'WhatsApp Статус', ratio: '9:16', dims: '1080×1920', icon: '💬' }
            ],
            screens: [
                { name: 'Full HD', ratio: '16:9', dims: '1920×1080', icon: '🖥️' },
                { name: '2K QHD', ratio: '16:9', dims: '2560×1440', icon: '🖥️' },
                { name: '4K UHD', ratio: '16:9', dims: '3840×2160', icon: '🖥️' },
                { name: 'Ultrawide', ratio: '21:9', dims: '2560×1080', icon: '🖥️' },
                { name: 'iPhone 15', ratio: '9:16', dims: '1179×2556', icon: '📱' },
                { name: 'iPad Pro', ratio: '3:4', dims: '2048×2732', icon: '📱' },
                { name: 'MacBook Pro', ratio: '16:9', dims: '3024×1964', icon: '💻' },
                { name: 'A4 Бумага', ratio: '3:4', dims: '2480×3508', icon: '📄' },
                { name: 'Фото 10×15', ratio: '2:3', dims: '1200×1800', icon: '🖨️' },
                { name: 'Кино (Scope)', ratio: '21:9', dims: '2560×1080', icon: '🎬' }
            ]
        };

        // ============ INITIALIZATION ============
        const uploadZone = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');

        // Drag & Drop
        uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadZone.classList.add('dragover');
        });

        uploadZone.addEventListener('dragleave', () => {
            uploadZone.classList.remove('dragover');
        });

        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('dragover');
            handleFiles(e.dataTransfer.files);
        });

        fileInput.addEventListener('change', (e) => {
            handleFiles(e.target.files);
        });

        // Paste from clipboard
        document.addEventListener('paste', (e) => {
            const items = e.clipboardData?.items;
            if (!items) return;
            for (let item of items) {
                if (item.type.startsWith('image/')) {
                    const file = item.getAsFile();
                    handleFiles([file]);
                    break;
                }
            }
        });

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'o') { e.preventDefault(); fileInput.click(); }
            if (e.ctrlKey && e.key === 'c' && state.currentImage) { e.preventDefault(); copyRatio(); }
            if (e.ctrlKey && e.key === 's' && state.currentImage) { e.preventDefault(); downloadImage(); }
            if (e.ctrlKey && e.key === 'e' && state.currentImage) { e.preventDefault(); openExportModal(); }
            if (e.ctrlKey && e.key === 'h') { e.preventDefault(); openHistory(); }
            if (e.key === 'f' && state.currentImage && !e.ctrlKey) { viewFullscreen(); }
            if (e.key === 'r' && state.currentImage && !e.ctrlKey) { rotateImage(); }
            if (e.key === 'Escape') {
                closeFullscreen();
                closeHistory();
                closeExportModal();
                closeShortcuts();
            }
            if (e.key === 't' && !e.ctrlKey) { toggleTheme(); }
        });

        // ============ FILE HANDLING ============
        function handleFiles(files) {
            if (!files || files.length === 0) return;

            state.images = [];
            for (let file of files) {
                if (file.type.startsWith('image/')) {
                    state.images.push(file);
                }
            }

            if (state.images.length === 0) {
                showToast('❌ Пожалуйста, загрузите файл изображения');
                return;
            }

            state.currentIndex = 0;
            showLoading();

            setTimeout(() => {
                processImage(state.images[0]);
                if (state.images.length > 1) {
                    buildImageStrip();
                }
            }, 600);
        }

        function processImage(file) {
            state.currentFile = file;
            state.rotation = 0;
            state.flipped = false;
            state.zoom = 1;

            const reader = new FileReader();
            reader.onload = (e) => {
                const img = new Image();
                img.onload = () => {
                    state.currentImage = img;
                    analyzeImage(img, file);
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        // ============ ANALYSIS ============
        function analyzeImage(img, file) {
            const w = img.naturalWidth;
            const h = img.naturalHeight;

            // Find best matching ratio
            const actualRatio = w / h;
            let bestMatch = null;
            let bestDiff = Infinity;

            for (let r of RATIOS) {
                const targetRatio = r.w / r.h;
                const diff = Math.abs(actualRatio - targetRatio) / targetRatio;
                if (diff < bestDiff) {
                    bestDiff = diff;
                    bestMatch = r;
                }
            }

            const accuracy = Math.max(0, (1 - bestDiff) * 100).toFixed(1);

            // Update UI
            hideLoading();
            document.getElementById('results').classList.add('active');
            document.getElementById('heroSection').style.display = 'none';
            document.getElementById('uploadZone').style.display = 'none';

            // Preview
            const previewImg = document.getElementById('previewImage');
            previewImg.src = img.src;
            previewImg.style.transform = '';

            // Ratio
            document.getElementById('ratioResult').textContent = bestMatch.name;
            document.getElementById('ratioLabel').textContent = getRatioDescription(bestMatch.name);
            document.getElementById('ratioAccuracy').style.display = 'inline-flex';
            document.getElementById('accuracyText').textContent = `${accuracy}% совпадение`;

            // Ratio visual
            const ratioVisual = document.getElementById('ratioVisual');
            ratioVisual.style.display = 'block';
            const maxDim = 120;
            const visualRatio = bestMatch.w / bestMatch.h;
            let vw, vh;
            if (visualRatio >= 1) {
                vw = maxDim;
                vh = maxDim / visualRatio;
            } else {
                vh = maxDim;
                vw = maxDim * visualRatio;
            }
            ratioVisual.style.width = vw + 'px';
            ratioVisual.style.height = vh + 'px';
            ratioVisual.style.maxWidth = '100%';
            ratioVisual.setAttribute('data-ratio', bestMatch.name);

            // File info
            document.getElementById('imgWidth').textContent = w.toLocaleString() + ' px';
            document.getElementById('imgHeight').textContent = h.toLocaleString() + ' px';
            document.getElementById('imgMegapixels').textContent = ((w * h) / 1000000).toFixed(2) + ' MP';
            document.getElementById('imgFileSize').textContent = formatFileSize(file.size);
            document.getElementById('imgFileType').textContent = file.type.split('/')[1].toUpperCase();
            document.getElementById('fileTypeBadge').textContent = file.type.split('/')[1].toUpperCase();
            document.getElementById('imgOrientation').textContent = w > h ? '🖼️ Альбомная' : (w < h ? '📱 Портретная' : '⬜ Квадратная');

            // Build ratio cards
            buildRatioCards(actualRatio, bestMatch.name);

            // Build platform suggestions
            buildPlatformSuggestions(bestMatch.name);

            // Extract colors
            extractColors(img);

            // Build crop options
            buildCropOptions(img, bestMatch);

            // Build analysis
            buildAnalysis(w, h, file, actualRatio);

            // Build comparison
            buildComparison(w, h);

            // Add to history
            addToHistory(file, bestMatch.name, w, h, accuracy);

            showToast('✅ Анализ завершён: ' + bestMatch.name);
        }

        // ============ RATIO CARDS ============
        function buildRatioCards(actualRatio, matchedName) {
            const container = document.getElementById('ratioCards');
            container.innerHTML = '';

            const sorted = RATIOS.map(r => {
                const targetRatio = r.w / r.h;
                const diff = Math.abs(actualRatio - targetRatio) / targetRatio * 100;
                return { ...r, diff };
            }).sort((a, b) => a.diff - b.diff);

            sorted.forEach(r => {
                const card = document.createElement('div');
                card.className = 'ratio-card' + (r.name === matchedName ? ' active' : '');
                
                const miniW = Math.min(36, 36 * (r.w / Math.max(r.w, r.h)));
                const miniH = Math.min(36, 36 * (r.h / Math.max(r.w, r.h)));
                
                card.innerHTML = `
                    <div class="ratio-mini">
                        <div class="ratio-mini-box" style="width:${miniW}px;height:${miniH}px;"></div>
                    </div>
                    <div class="ratio-name">${r.name}</div>
                    <div class="ratio-diff">${r.diff < 0.1 ? '✓ Точно' : (r.diff < 5 ? '≈ ' + r.diff.toFixed(1) + '%' : r.diff.toFixed(1) + '% откл.')}</div>
                `;

                card.addEventListener('click', () => {
                    showToast(`📐 ${r.name} — Отклонение: ${r.diff.toFixed(2)}%`);
                });

                container.appendChild(card);
            });
        }

        // ============ PLATFORM SUGGESTIONS ============
        function buildPlatformSuggestions(matchedRatio) {
            const socialContainer = document.getElementById('socialSuggestions');
            const screenContainer = document.getElementById('screenSuggestions');

            socialContainer.innerHTML = '';
            screenContainer.innerHTML = '';

            PLATFORMS.social.forEach(p => {
                const match = p.ratio === matchedRatio;
                socialContainer.innerHTML += `
                    <div class="suggestion-item">
                        <div class="platform">
                            <div class="match-indicator ${match ? 'match-good' : (isClose(p.ratio, matchedRatio) ? 'match-ok' : 'match-bad')}"></div>
                            <span>${p.icon} ${p.name}</span>
                        </div>
                        <div class="dims">${p.dims} (${p.ratio})</div>
                    </div>
                `;
            });

            PLATFORMS.screens.forEach(p => {
                const match = p.ratio === matchedRatio;
                screenContainer.innerHTML += `
                    <div class="suggestion-item">
                        <div class="platform">
                            <div class="match-indicator ${match ? 'match-good' : (isClose(p.ratio, matchedRatio) ? 'match-ok' : 'match-bad')}"></div>
                            <span>${p.icon} ${p.name}</span>
                        </div>
                        <div class="dims">${p.dims} (${p.ratio})</div>
                    </div>
                `;
            });
        }

        function isClose(r1, r2) {
            const parseRatio = r => { const [a, b] = r.split(':').map(Number); return a / b; };
            return Math.abs(parseRatio(r1) - parseRatio(r2)) < 0.2;
        }

        // ============ COLOR EXTRACTION ============
        function extractColors(img) {
            const canvas = document.getElementById('processingCanvas');
            const ctx = canvas.getContext('2d');
            const maxDim = 200;
            const scale = Math.min(maxDim / img.naturalWidth, maxDim / img.naturalHeight, 1);
            canvas.width = img.naturalWidth * scale;
            canvas.height = img.naturalHeight * scale;
            ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            const data = imageData.data;

            // Simple color quantization using k-means approximation
            const colorMap = {};
            let totalBrightness = 0;
            let warmCount = 0, coolCount = 0, neutralCount = 0;

            for (let i = 0; i < data.length; i += 16) {
                const r = Math.round(data[i] / 32) * 32;
                const g = Math.round(data[i + 1] / 32) * 32;
                const b = Math.round(data[i + 2] / 32) * 32;
                const key = `${r},${g},${b}`;
                colorMap[key] = (colorMap[key] || 0) + 1;

                const brightness = (data[i] + data[i + 1] + data[i + 2]) / 3;
                totalBrightness += brightness;

                // Temperature
                if (data[i] > data[i + 2] + 30) warmCount++;
                else if (data[i + 2] > data[i] + 30) coolCount++;
                else neutralCount++;
            }

            const totalSamples = data.length / 16;
            const avgBrightness = (totalBrightness / totalSamples / 255 * 100).toFixed(0);

            // Sort colors by frequency
            const sortedColors = Object.entries(colorMap)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 10);

            const totalCount = sortedColors.reduce((s, c) => s + c[1], 0);

            // Build palette
            const paletteContainer = document.getElementById('colorPalette');
            paletteContainer.innerHTML = '';

            sortedColors.forEach(([color, count]) => {
                const [r, g, b] = color.split(',').map(Number);
                const hex = rgbToHex(r, g, b);
                const swatch = document.createElement('div');
                swatch.className = 'color-swatch';
                swatch.style.background = `rgb(${r},${g},${b})`;
                swatch.innerHTML = `<span class="color-hex">${hex}</span>`;
                swatch.onclick = () => {
                    navigator.clipboard.writeText(hex);
                    showToast(`🎨 Скопировано: ${hex}`);
                };
                paletteContainer.appendChild(swatch);
            });

            // Color table
            const tableBody = document.getElementById('colorTableBody');
            tableBody.innerHTML = '';
            sortedColors.forEach(([color, count]) => {
                const [r, g, b] = color.split(',').map(Number);
                const hex = rgbToHex(r, g, b);
                const pct = (count / totalCount * 100).toFixed(1);
                tableBody.innerHTML += `
                    <tr>
                        <td><div style="width:20px;height:20px;border-radius:4px;background:rgb(${r},${g},${b});display:inline-block;vertical-align:middle;"></div></td>
                        <td style="cursor:pointer;" onclick="navigator.clipboard.writeText('${hex}');showToast('📋 ${hex}')">${hex}</td>
                        <td>${r}, ${g}, ${b}</td>
                        <td>${pct}%</td>
                    </tr>
                `;
            });

            // Histogram
            const histogram = document.getElementById('colorHistogram');
            histogram.innerHTML = '';
            const maxCount = sortedColors[0][1];
            sortedColors.forEach(([color, count]) => {
                const [r, g, b] = color.split(',').map(Number);
                const height = (count / maxCount * 100);
                const bar = document.createElement('div');
                bar.className = 'histogram-bar';
                bar.style.height = height + '%';
                bar.style.background = `rgb(${r},${g},${b})`;
                bar.style.flex = '1';
                histogram.appendChild(bar);
            });

            // Temperature
            const tempTotal = warmCount + coolCount + neutralCount;
            document.getElementById('warmSegment').style.flex = warmCount / tempTotal;
            document.getElementById('coolSegment').style.flex = coolCount / tempTotal;
            document.getElementById('neutralSegment').style.flex = neutralCount / tempTotal;

            // Brightness
            document.getElementById('brightnessFill').style.width = avgBrightness + '%';
            document.getElementById('brightnessValue').textContent = avgBrightness + '%';
        }

        function rgbToHex(r, g, b) {
            return '#' + [r, g, b].map(x => Math.min(255, x).toString(16).padStart(2, '0')).join('');
        }

        // ============ CROP ============
        function buildCropOptions(img, currentRatio) {
            const container = document.getElementById('cropOptions');
            container.innerHTML = '';

            RATIOS.forEach(r => {
                const btn = document.createElement('button');
                btn.className = 'crop-btn' + (r.name === currentRatio.name ? ' selected' : '');
                btn.textContent = r.name;
                btn.onclick = () => {
                    container.querySelectorAll('.crop-btn').forEach(b => b.classList.remove('selected'));
                    btn.classList.add('selected');
                    state.selectedCropRatio = r;
                    drawCrop(img, r);
                };
                container.appendChild(btn);
            });

            state.selectedCropRatio = currentRatio;
            drawCrop(img, currentRatio);
        }

        function drawCrop(img, ratio) {
            const canvas = document.getElementById('cropCanvas');
            const ctx = canvas.getContext('2d');

            const targetRatio = ratio.w / ratio.h;
            let cropW, cropH;

            if (img.naturalWidth / img.naturalHeight > targetRatio) {
                cropH = img.naturalHeight;
                cropW = cropH * targetRatio;
            } else {
                cropW = img.naturalWidth;
                cropH = cropW / targetRatio;
            }

            const sx = (img.naturalWidth - cropW) / 2;
            const sy = (img.naturalHeight - cropH) / 2;

            const maxDisplay = 600;
            const displayScale = Math.min(maxDisplay / cropW, maxDisplay / cropH, 1);
            canvas.width = cropW * displayScale;
            canvas.height = cropH * displayScale;

            ctx.drawImage(img, sx, sy, cropW, cropH, 0, 0, canvas.width, canvas.height);

            document.getElementById('cropDimensions').textContent = 
                `${Math.round(cropW)} × ${Math.round(cropH)} px (${ratio.name})`;
        }

        function downloadCropped() {
            if (!state.currentImage || !state.selectedCropRatio) return;

            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            const img = state.currentImage;
            const ratio = state.selectedCropRatio;

            const targetRatio = ratio.w / ratio.h;
            let cropW, cropH;

            if (img.naturalWidth / img.naturalHeight > targetRatio) {
                cropH = img.naturalHeight;
                cropW = cropH * targetRatio;
            } else {
                cropW = img.naturalWidth;
                cropH = cropW / targetRatio;
            }

            const sx = (img.naturalWidth - cropW) / 2;
            const sy = (img.naturalHeight - cropH) / 2;

            canvas.width = cropW;
            canvas.height = cropH;
            ctx.drawImage(img, sx, sy, cropW, cropH, 0, 0, cropW, cropH);

            canvas.toBlob(blob => {
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `cropped_${ratio.name.replace(':', 'x')}_${Date.now()}.png`;
                a.click();
                URL.revokeObjectURL(url);
                showToast('💾 Кадрированное изображение сохранено!');
            });
        }

        // ============ ANALYSIS ============
        function buildAnalysis(w, h, file, actualRatio) {
            const totalPx = w * h;
            document.getElementById('totalPixels').textContent = totalPx.toLocaleString();

            const printW = (w / 300 * 2.54).toFixed(1);
            const printH = (h / 300 * 2.54).toFixed(1);
            document.getElementById('printSize').textContent = `${printW} × ${printH} см`;

            const mp = totalPx / 1000000;
            let rec;
            if (mp >= 12) rec = '🟢 Отлично для печати крупного формата';
            else if (mp >= 5) rec = '🟡 Хорошо для стандартной печати';
            else if (mp >= 2) rec = '🟠 Подходит для веб и малой печати';
            else rec = '🔴 Только для веб-использования';
            document.getElementById('qualityRec').textContent = rec;

            const diagonal = Math.sqrt(w * w + h * h).toFixed(0);
            document.getElementById('diagonal').textContent = Number(diagonal).toLocaleString() + ' px';
            document.getElementById('perimeter').textContent = ((w + h) * 2).toLocaleString() + ' px';
            document.getElementById('area').textContent = totalPx.toLocaleString() + ' px²';
            document.getElementById('decimalRatio').textContent = actualRatio.toFixed(4);

            // Scale list
            const scaleList = document.getElementById('scaleList');
            scaleList.innerHTML = '';
            [0.25, 0.5, 0.75, 1.5, 2, 3, 4].forEach(s => {
                const sw = Math.round(w * s);
                const sh = Math.round(h * s);
                scaleList.innerHTML += `
                    <div class="suggestion-item">
                        <div class="platform">
                            <span>${s < 1 ? '🔽' : '🔼'} ${s * 100}%</span>
                        </div>
                        <div class="dims">${sw.toLocaleString()} × ${sh.toLocaleString()}</div>
                    </div>
                `;
            });
        }

        // ============ COMPARISON ============
        function buildComparison(w, h) {
            const container = document.getElementById('comparisonGrid');
            container.innerHTML = '';

            RATIOS.forEach(r => {
                const ratio = r.w / r.h;
                const maxSize = 80;
                let bw, bh;
                if (ratio >= 1) {
                    bw = maxSize;
                    bh = maxSize / ratio;
                } else {
                    bh = maxSize;
                    bw = maxSize * ratio;
                }

                // Calc dimensions if we keep the larger dimension
                let newW, newH;
                if (w / h > ratio) {
                    newH = h;
                    newW = Math.round(h * ratio);
                } else {
                    newW = w;
                    newH = Math.round(w / ratio);
                }

                container.innerHTML += `
                    <div class="comparison-item">
                        <div class="comparison-box" style="width:${bw}px;height:${bh}px;"></div>
                        <div class="comparison-label">${r.name}</div>
                        <div class="comparison-dims">${newW.toLocaleString()} × ${newH.toLocaleString()}</div>
                    </div>
                `;
            });
        }

        // ============ IMAGE STRIP ============
        function buildImageStrip() {
            const strip = document.getElementById('imageStrip');
            strip.style.display = 'flex';
            strip.innerHTML = '';

            state.images.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const thumb = document.createElement('img');
                    thumb.className = 'strip-thumb' + (index === state.currentIndex ? ' active' : '');
                    thumb.src = e.target.result;
                    thumb.onclick = () => {
                        state.currentIndex = index;
                        processImage(state.images[index]);
                        strip.querySelectorAll('.strip-thumb').forEach(t => t.classList.remove('active'));
                        thumb.classList.add('active');
                    };
                    strip.appendChild(thumb);
                };
                reader.readAsDataURL(file);
            });

            const addBtn = document.createElement('div');
            addBtn.className = 'strip-add';
            addBtn.textContent = '+';
            addBtn.onclick = () => fileInput.click();
            strip.appendChild(addBtn);
        }

        // ============ HISTORY ============
        function addToHistory(file, ratio, w, h, accuracy) {
            const entry = {
                name: file.name || 'Вставленное изображение',
                ratio: ratio,
                width: w,
                height: h,
                accuracy: accuracy,
                size: formatFileSize(file.size),
                date: new Date().toLocaleString('ru-RU'),
                thumbnail: state.currentImage.src.substring(0, 200)
            };

            state.history.unshift(entry);
            if (state.history.length > 50) state.history.pop();
            localStorage.setItem('aspectlens_history', JSON.stringify(state.history));
        }

        function openHistory() {
            document.getElementById('historyModal').classList.add('active');
            const list = document.getElementById('historyList');

            if (state.history.length === 0) {
                list.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:2rem;">История пуста</p>';
                return;
            }

            list.innerHTML = '';
            state.history.forEach((entry, i) => {
                list.innerHTML += `
                    <div class="history-item">
                        <div style="width:50px;height:50px;background:var(--bg-card);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">🖼️</div>
                        <div class="history-info">
                            <div class="name">${entry.name}</div>
                            <div class="meta">${entry.width}×${entry.height} • ${entry.size} • ${entry.date}</div>
                        </div>
                        <div class="history-ratio">${entry.ratio}</div>
                    </div>
                `;
            });
        }

        function closeHistory() { document.getElementById('historyModal').classList.remove('active'); }
        
        function clearHistory() {
            state.history = [];
            localStorage.removeItem('aspectlens_history');
            openHistory();
            showToast('🗑️ История очищена');
        }

        // ============ EXPORT ============
        function openExportModal() {
            if (!state.currentImage) return;
            document.getElementById('exportModal').classList.add('active');

            const content = document.getElementById('exportContent');
            const ratio = document.getElementById('ratioResult').textContent;
            const w = state.currentImage.naturalWidth;
            const h = state.currentImage.naturalHeight;

            content.innerHTML = `
                <div style="background:var(--bg-secondary);padding:1.5rem;border-radius:var(--radius-sm);border:1px solid var(--border);font-family:monospace;font-size:0.85rem;line-height:1.8;white-space:pre-wrap;" id="reportText">
═══════════════════════════════════
    ASPECTLENS — ОТЧЁТ АНАЛИЗА
═══════════════════════════════════

📐 Соотношение сторон: ${ratio}
📏 Размеры: ${w} × ${h} px
📊 Мегапиксели: ${((w * h) / 1000000).toFixed(2)} MP
📁 Тип файла: ${state.currentFile?.type || 'N/A'}
📦 Размер: ${formatFileSize(state.currentFile?.size || 0)}
🧭 Ориентация: ${w > h ? 'Альбомная' : (w < h ? 'Портретная' : 'Квадратная')}

📐 Геометрия:
  • Диагональ: ${Math.sqrt(w * w + h * h).toFixed(0)} px
  • Периметр: ${((w + h) * 2).toLocaleString()} px
  • Площадь: ${(w * h).toLocaleString()} px²
  • Десятичное: ${(w / h).toFixed(4)}

🖨️ Печать (300 DPI):
  • ${(w / 300 * 2.54).toFixed(1)} × ${(h / 300 * 2.54).toFixed(1)} см

───────────────────────────────────
  Сгенерировано: ${new Date().toLocaleString('ru-RU')}
  AspectLens v1.0
═══════════════════════════════════</div>
            `;
        }

        function closeExportModal() { document.getElementById('exportModal').classList.remove('active'); }

        function copyReport() {
            const text = document.getElementById('reportText')?.textContent;
            if (text) {
                navigator.clipboard.writeText(text);
                showToast('📋 Отчёт скопирован');
            }
        }

        function downloadReport() {
            const text = document.getElementById('reportText')?.textContent;
            if (!text) return;
            const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `aspectlens_report_${Date.now()}.txt`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('💾 Отчёт сохранён');
        }

        function downloadJSON() {
            if (!state.currentImage) return;
            const w = state.currentImage.naturalWidth;
            const h = state.currentImage.naturalHeight;
            const data = {
                ratio: document.getElementById('ratioResult').textContent,
                width: w,
                height: h,
                megapixels: parseFloat(((w * h) / 1000000).toFixed(2)),
                fileType: state.currentFile?.type,
                fileSize: state.currentFile?.size,
                orientation: w > h ? 'landscape' : (w < h ? 'portrait' : 'square'),
                diagonal: parseFloat(Math.sqrt(w * w + h * h).toFixed(0)),
                decimalRatio: parseFloat((w / h).toFixed(4)),
                printSize: {
                    widthCm: parseFloat((w / 300 * 2.54).toFixed(1)),
                    heightCm: parseFloat((h / 300 * 2.54).toFixed(1))
                },
                generatedAt: new Date().toISOString()
            };

            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `aspectlens_data_${Date.now()}.json`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('📦 JSON сохранён');
        }

        // ============ SHORTCUTS MODAL ============
        function openShortcuts() { document.getElementById('shortcutsModal').classList.add('active'); }
        function closeShortcuts() { document.getElementById('shortcutsModal').classList.remove('active'); }

        // ============ IMAGE TOOLS ============
        function rotateImage() {
            if (!state.currentImage) return;
            state.rotation = (state.rotation + 90) % 360;
            applyTransform();
            showToast('🔄 Повёрнуто на 90°');
        }

        function flipImage() {
            if (!state.currentImage) return;
            state.flipped = !state.flipped;
            applyTransform();
            showToast('↔️ Изображение отражено');
        }

        function applyTransform() {
            const img = document.getElementById('previewImage');
            img.style.transform = `rotate(${state.rotation}deg) scaleX(${state.flipped ? -1 : 1}) scale(${state.zoom})`;
        }

        function zoomIn() {
            state.zoom = Math.min(5, state.zoom + 0.25);
            applyTransform();
        }

        function zoomOut() {
            state.zoom = Math.max(0.25, state.zoom - 0.25);
            applyTransform();
        }

        function zoomReset() {
            state.zoom = 1;
            applyTransform();
        }

        function viewFullscreen() {
            if (!state.currentImage) return;
            const overlay = document.getElementById('fullscreenOverlay');
            document.getElementById('fullscreenImage').src = state.currentImage.src;
            overlay.classList.add('active');
        }

        function closeFullscreen() {
            document.getElementById('fullscreenOverlay').classList.remove('active');
        }

        function downloadImage() {
            if (!state.currentImage) return;
            const a = document.createElement('a');
            a.href = state.currentImage.src;
            a.download = state.currentFile?.name || `image_${Date.now()}.png`;
            a.click();
            showToast('💾 Изображение сохранено');
        }

        function copyRatio() {
            const ratio = document.getElementById('ratioResult').textContent;
            if (ratio && ratio !== '—') {
                navigator.clipboard.writeText(ratio);
                showToast('📋 Скопировано: ' + ratio);
            }
        }

        // ============ UI HELPERS ============
        function showLoading() {
            document.getElementById('loading').classList.add('active');
            document.getElementById('results').classList.remove('active');
        }

        function hideLoading() {
            document.getElementById('loading').classList.remove('active');
        }

        function resetAll() {
            state.currentImage = null;
            state.currentFile = null;
            state.rotation = 0;
            state.flipped = false;
            state.zoom = 1;
            state.images = [];

            document.getElementById('results').classList.remove('active');
            document.getElementById('heroSection').style.display = '';
            document.getElementById('uploadZone').style.display = '';
            document.getElementById('imageStrip').style.display = 'none';
            fileInput.value = '';
            showToast('🔄 Сброшено');
        }

        function switchTab(btn, tabId) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById(tabId).classList.add('active');
        }

        function toggleTheme() {
            const html = document.documentElement;
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            document.getElementById('themeToggle').textContent = next === 'dark' ? '🌙' : '☀️';
            localStorage.setItem('aspectlens_theme', next);
            showToast(next === 'dark' ? '🌙 Тёмная тема' : '☀️ Светлая тема');
        }

        function showToast(message) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        function formatFileSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / 1024 / 1024).toFixed(2) + ' MB';
        }

        function getRatioDescription(ratio) {
            const descriptions = {
                '1:1': 'Квадрат — Идеально для аватаров и Instagram',
                '1:4': 'Узкий вертикальный баннер',
                '4:1': 'Широкий горизонтальный баннер',
                '1:8': 'Экстремально узкий вертикальный',
                '8:1': 'Экстремально широкий горизонтальный',
                '2:3': 'Классический портрет — Фото 10×15',
                '3:2': 'Классический пейзаж — Стандартное фото',
                '3:4': 'Портрет — iPad, фото 3:4',
                '4:3': 'Стандартный формат — ТВ, мониторы',
                '4:5': 'Портрет Instagram',
                '5:4': 'Лёгкий пейзаж — 8×10 фото',
                '9:16': 'Вертикальное видео — Stories, Reels',
                '16:9': 'Широкоэкранный — Full HD, YouTube',
                '21:9': 'Ультраширокий — Кино, UltraWide'
            };
            return descriptions[ratio] || 'Пользовательское соотношение';
        }

        // Load saved theme
        const savedTheme = localStorage.getItem('aspectlens_theme');
        if (savedTheme) {
            document.documentElement.setAttribute('data-theme', savedTheme);
            document.getElementById('themeToggle').textContent = savedTheme === 'dark' ? '🌙' : '☀️';
        }
    </script>
</body>
</html>
